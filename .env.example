# ---- Runtime ----
ENV=development
LOG_LEVEL=INFO

# Single-worker is enforced at boot (see AGENTS.md "Single-worker constraint").
# Any value other than "1" fails the lifespan startup loud.
WEB_CONCURRENCY=1

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://synapseai:synapseai_dev@db:5432/synapseai
DB_PASSWORD=synapseai_dev

# ---- Upload ----
UPLOAD_DIR=/data/uploads

# ---- CORS ----
# JSON list. `"*"` is rejected at boot because `allow_credentials=True`
# is incompatible with a wildcard origin (browsers silently drop the response).
CORS_ORIGINS=["http://localhost:5173"]

# ---- Rate limiting ----
# IPs or CIDRs of reverse proxies whose `X-Forwarded-For` header we trust.
# Empty list ("trust nothing") is the safe default when running without a
# proxy. Never set to a wide range — untrusted peers can spoof XFF.
TRUSTED_PROXIES=[]
